{
  "name": "cursor-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "飞书 ↔ Cursor Agent（含定时任务）+ real-browser MCP",
  "type": "module",
  "bin": {
    "lark-channel-bridge": "./bin/lark-channel-bridge.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "lark-bridge:cursor": "npm run build && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-lark-bridge.ps1",
    "lark-bridge:restart": "npm run build && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/restart-lark-bridge.ps1",
    "lark-bridge:status": "lark-channel-bridge status"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "@cursor/sdk": "^1.0.18",
    "@larksuiteoapi/node-sdk": "^1.65.0",
    "commander": "^12.1.0",
    "cron-parser": "^5.3.0",
    "cross-spawn": "^7.0.6",
    "graceful-fs": "^4.2.11",
    "https-proxy-agent": "^9.0.0",
    "proper-lockfile": "^4.1.2",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/graceful-fs": "^4.1.9",
    "@types/node": "^22.10.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/qrcode-terminal": "^0.12.2",
    "real-browser-mcp": "1.2.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.12.0"
  }
}
