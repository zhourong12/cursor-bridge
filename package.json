{
  "name": "cursor-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "飞书 ↔ Cursor Agent bridge（含 /schedule 定时任务）",
  "type": "module",
  "main": "desktop/electron-main.cjs",
  "bin": {
    "lark-channel-bridge": "./bin/lark-channel-bridge.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup && node scripts/copy-admin-static.mjs",
    "restart": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/restart-lark-bridge.ps1",
    "restart:build": "npm run build && npm run restart",
    "lark-bridge:cursor": "npm run build && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-lark-bridge.ps1",
    "lark-bridge:cursor:mac": "npm run build && bash ./start-mac.sh",
    "lark-bridge:restart": "npm run restart:build",
    "lark-bridge:status": "lark-channel-bridge status",
    "fleet:start": "lark-channel-bridge fleet start --all",
    "fleet:stop": "lark-channel-bridge fleet stop --all",
    "fleet:status": "lark-channel-bridge fleet status --all",
    "fleet:restart": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/restart-fleet.ps1",
    "fleet:restart:all": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/restart-fleet.ps1 -All",
    "fleet:restart:build": "npm run build && npm run fleet:restart",
    "lark-bridge:fleet-restart": "npm run fleet:restart:build",
    "lark-bridge:fleet-restart:all": "npm run build && npm run fleet:restart:all",
    "console": "electron desktop/electron-main.cjs",
    "console:serve": "lark-channel-bridge admin serve",
    "console:pack": "npm run build && electron-builder --win portable",
    "console:run": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/console.ps1 run",
    "console:run:portable": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/console.ps1 run -Portable",
    "console:run:build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/console.ps1 run -Build",
    "console:web": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-console-web.ps1",
    "console:web:build": "npm run build && npm run console:web",
    "verify:console": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-console.ps1",
    "pack:console": "electron-builder --win portable",
    "pack:console:installer": "npm run build && electron-builder --win nsis"
  },
  "build": {
    "appId": "ai.lark-bridge.console",
    "productName": "Bridge Console",
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "electronLanguages": [
      "zh-CN",
      "en-US"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/electron-main.cjs",
      "desktop/electron-preload.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist",
        "to": "bridge/dist"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "BridgeConsole-${version}-portable.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "BridgeConsole-${version}-setup.${ext}"
    }
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "@cursor/sdk": "^1.0.22",
    "@larksuiteoapi/node-sdk": "^1.65.0",
    "commander": "^12.1.0",
    "cron-parser": "^5.3.0",
    "cross-spawn": "^7.0.6",
    "graceful-fs": "^4.2.11",
    "https-proxy-agent": "^9.0.0",
    "proper-lockfile": "^4.1.2",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/graceful-fs": "^4.1.9",
    "@types/node": "^22.10.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/qrcode-terminal": "^0.12.2",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.12.0"
  }
}
